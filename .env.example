# Backend
# Use a non-secret placeholder here. Set the real value in your local `.env` (not committed).
API_KEY=CHANGE_ME

# When running via docker-compose, use the service name 'redis'
REDIS_URL=redis://redis:6379/0

# AI models
# - Summarization defaults to a transformer in code if available (with fallback)
# - Keep these as defaults unless you need to override behavior
SUMMARIZATION_MODEL=sshleifer/distilbart-cnn-12-6
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
SPACY_MODEL=en_core_web_sm

# OCR
# Docker image includes tesseract; leave empty.
# On Windows (non-docker), set this if tesseract isn't on PATH.
TESSERACT_CMD=

# CORS
# Comma-separated list
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend (Next.js)
# Base URL where the backend API is reachable from the browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
